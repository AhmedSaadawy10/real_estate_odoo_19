<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="inherit_view_users_form" model="ir.ui.view">
            <field name="name">view.user.form.inherit</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                <page string="Properties">
                    <field name="property_ids" context="{'default_salesperson_id': uid}">
                        <list>
                            <field name="name"/>
                            <field name="state"/>
                            <field name="selling_price"/>
                            <field name="buyer_id"/>
                        </list>
                        <form>
                            <group>
                                <field name="name"/>
                                <field name="state"/>
                                <field name="selling_price"/>
                                <field name="buyer_id"/>
                            </group>
                        </form>
                    </field>
                </page>
            </xpath>
            </field>

        </record>
    </data>
</odoo>