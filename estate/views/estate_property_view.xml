<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>

        <!--define estate property search view -->
        <record id="estate_property_view_search" model="ir.ui.view">
            <field name="name">estate.property.view.search</field>
            <field name="model">real.estate</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Title" filter_domain="[('name','ilike','self')]"/>
                    <field name="postcode" string="Postcode"/>
                    <field name="expected_price" string="Expected Price"/>
                    <field name="bedrooms" string="Bed Rooms"/>
                    <field name="living_area" string="Living Area" filter_domain="[('living_area',&gt;, '')]"/>
                        <separator string="State Filter"/>
                    <filter name="filter_state_new" string="New" domain="[('state','=', 'new')]"/>
                    <filter name="filter_state_received" string="Offer Received" domain="[('state','=', 'received')]"/>
                    <filter name="filter_state_accepted" string="Offer Accepted" domain="[('state','=', 'accepted')]"/>
                    <filter name="filter_state_sold" string="Sold" domain="[('state','=', 'sold')]"/>
                    <filter name="filter_state_canceled" string="Canceled" domain="[('state','=', 'canceled')]"/>

                    <group>
                        <filter name="group_by_postcode" context="{'group_by': 'postcode'}"/>
                    </group>

                </search>
            </field>
        </record>
        <!--define estate property form view -->
        <record id="estate_property_view_form" model="ir.ui.view">
            <field name="name">estate.property.view.form</field>
            <field name="model">real.estate</field>
            <field name="arch" type="xml">
                <form>
                    <!--TODO: Result from converting "states='sold, canceled'" attribute into an 'invisible' attribute
                         Manually combine states condition into any 'invisible' overrides in inheriting views as well-->
                    <header invisible="state not in ['sold', 'canceled']">
                        <button type="object" name="action_sold" string="Sold" class="btn btn-primary"/>
                        <button type="object" name="action_canceled" string="Canceled" class="btn btn-secondary"/>
                        <button type="object" name="get_properties" string="List Properties" class="btn btn-secondary"/>
                        <field name="state" widget="statusbar" statusbar_visible="new, received, accepted"/>
                    </header>
                    <sheet>
                        <h1>
                            <field name="name"/>
                        </h1>
                        <group>
                            <group>
                                <field name="property_type_id" string="Property Type" widget="selection"/>
                                <field name="state"/>
                                <field name="postcode"/>
                                <field name="tag_ids" widget="many2many_tags" options="{'color': 'color'}"/>
                            </group>
                            <group>
                                <field name="date_availability"/>
                                <field name="expected_price" widget="monetary"/>
                                <field name="selling_price" widget="monetary"/>
                                <field name="best_price" widget="monetary"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Description">
                                <group>
                                    <field name="description"/>
                                    <field name="bedrooms"/>
                                    <field name="living_area"/>
                                    <field name="garage"/>
                                    <field name="garden"/>
                                    <field name="garden_area" invisible="garden == 'False'"/>
                                    <field name="garden_orientation" widget="radio"/>
                                    <field name="total_area"/>
                                </group>
                            </page>

                            <page string="Offers">
                                <field name="offer_ids" string="Offer">
                                    <list>
                                        <field name="partner_id"/>
                                        <field name="price"/>
                                        <field name="date_deadline"/>
                                        <field name="validity"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Other Info">
                                <group>
                                    <field name="buyer_id" string="Buyer"/>
                                    <field name="salesperson_id" string="Salesman"/>
                                </group>
                            </page>

                        </notebook>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>


        <!--define estate property list view -->
        <record id="estate_property_view_tree" model="ir.ui.view">
            <field name="name">estate.property.view.tree</field>
            <field name="model">real.estate</field>
            <field name="arch" type="xml">
                <list decoration-success="state == 'received' or state == 'accepted'" decoration-muted="state == 'sold'" decoration-bf="state == 'accepted'">
                    <field name="name" string="Title"/>
                    <field name="postcode"/>
                    <field name="bedrooms"/>
                    <field name="living_area"/>
                    <field name="expected_price"/>
                    <field name="selling_price"/>
                    <field name="date_availability"/>
                    <field name="state" optional="False"/>

                </list>
            </field>
        </record>

        <record id="real_estate_action" model="ir.actions.act_window">
            <field name="name">Real Estates</field>
            <field name="res_model">real.estate</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_filter_state_accepted':True,}</field>
        </record>
    </data>
</odoo>