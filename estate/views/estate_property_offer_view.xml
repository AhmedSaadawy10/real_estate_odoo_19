<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>

        <!--define estate property search view -->
        <record id="estate_property_offer_view_search" model="ir.ui.view">
            <field name="name">estate.property.offer.view.search</field>
            <field name="model">estate.property.offer</field>
            <field name="arch" type="xml">
                <search string="Property Offers Search">
                    <field name="price" string="Price"/>
                    <group>
                        <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    </group>
                </search>
            </field>
        </record>
        <!--define estate property form view -->
        <record id="estate_property_offer_view_form" model="ir.ui.view">
            <field name="name">estate.property.offer.view.form</field>
            <field name="model">estate.property.offer</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="price"/>
                            <field name="status"/>
                            <field name="partner_id"/>
                        </group>

                        <group>
                            <field name="property_id"/>
                            <field name="property_type_id"/>
                            <field name="validity"/>
                            <field name="date_deadline"/>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <!--define estate property list view -->
        <record id="estate_property_offer_view_tree" model="ir.ui.view">
            <field name="name">estate.property.offer.view.tree</field>
            <field name="model">estate.property.offer</field>
            <field name="arch" type="xml">
                <list string="Offers" decoration-success="status == 'accepted'" decoration-danger="status == 'refused'" editable="top">
                    <field name="partner_id"/>
                    <field name="price"/>
                    <field name="property_id"/>
                    <field name="property_type_id"/>
                    <field name="validity"/>
                    <field name="date_deadline"/>
                    <button name="action_accept" title="accept" type="object" icon="fa-check" invisible="status in ('accepted', 'refused')"/>
                    <!--TODO: Result from converting "states='accepted, refused'" attribute into an 'invisible' attribute
                         Manually combine states condition into any 'invisible' overrides in inheriting views as well-->
                    <button name="action_refuse" title="refuse" type="object" icon="fa-times" invisible="status not in ['accepted', 'refused']"/>
                    <field name="status" optional="False"/>

                </list>
            </field>
        </record>

        <record id="estate_property_offer_action" model="ir.actions.act_window">
            <field name="name">Estate Property Offer</field>
            <field name="res_model">estate.property.offer</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>